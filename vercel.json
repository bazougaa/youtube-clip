{
  "functions": {
    "api/index.js": {
      "maxDuration": 60,
      "includeFiles": [
        "bin/**",
        "node_modules/yt-dlp-exec/**",
        "node_modules/ffmpeg-static/**"
      ]
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.js"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
