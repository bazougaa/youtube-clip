{
  "functions": {
    "api/index.js": {
      "maxDuration": 60,
      "includeFiles": "node_modules/{yt-dlp-exec,ffmpeg-static}/**"
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.js"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}